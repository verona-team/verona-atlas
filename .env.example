# ===========================================
# Atlas - QA Agent Platform
# ===========================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Encryption (64-char hex string = 32 bytes for AES-256-GCM)
ENCRYPTION_KEY=

# Modal (compute layer for test execution)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# AgentMail (programmatic email inboxes for 2FA)
AGENTMAIL_API_KEY=

# Google Gemini API (chat orchestrator, research orchestrator + code writer,
# codebase exploration agent, flow-proposal generator, and outer QA ReAct
# agent all run on Gemini 3.1 Pro; conversation-context summarizer and the
# post-run Slack executive summary run on Gemini 3 Flash).
# `GOOGLE_API_KEY` is preferred; `GEMINI_API_KEY` is also accepted by
# langchain-google-genai as a fallback.
GOOGLE_API_KEY=

# Anthropic / Claude API (Stagehand browser agent on Modal — Claude Opus 4.7
# is used by the inner Stagehand CUA agent that actually drives the browser
# during test runs).
ANTHROPIC_API_KEY=

# GitHub App (repo access for commit analysis)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=atlas-qa
GITHUB_WEBHOOK_SECRET=
# OAuth credentials from the GitHub App page. Required for the
# "Connect GitHub" flow to work correctly when the app is already
# installed on the user's GitHub account (otherwise the install URL
# dead-ends on GitHub's "Configure" page and never returns a code).
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# Slack (OAuth bot for reporting)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Browserbase (cloud browser sessions - used by Modal runner)
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# PostHog (optional default API host - users can override per-project)
# POSTHOG_API_HOST=https://us.posthog.com

# App (used for Supabase email confirmation redirects; no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
