# ===========================================
# Atlas - QA Agent Platform
# ===========================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Encryption (64-char hex string = 32 bytes for AES-256-GCM)
ENCRYPTION_KEY=

# Modal (compute layer for test execution)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# AgentMail (programmatic email inboxes for 2FA)
AGENTMAIL_API_KEY=

# Anthropic / Claude API (outer QA agent, Slack summaries, and Stagehand browser agent on Modal)
ANTHROPIC_API_KEY=

# OpenAI (used only by the landing page "communal museum" image generation)
# Recommend using a separate key tied to a capped spending card ($300 cap per user plan).
OPENAI_API_KEY=

# GitHub App (repo access for commit analysis)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=atlas-qa
GITHUB_WEBHOOK_SECRET=

# Slack (OAuth bot for reporting)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Browserbase (cloud browser sessions - used by Modal runner)
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# PostHog (optional default API host - users can override per-project)
# POSTHOG_API_HOST=https://us.posthog.com

# App (used for Supabase email confirmation redirects; no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
